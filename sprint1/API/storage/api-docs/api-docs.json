                        "name": "by_category",
                        "in": "query",
                        "description": "Comma-separated list of category ids",
                        "required": false,
                        "schema": {
                            "description": "Comma-separated list of ids, e.g. 1,2,3",
                            "type": "string",
                            "example": "1,2,3"
                        }
                    },
